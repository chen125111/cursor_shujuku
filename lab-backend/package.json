    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma": "^6.0.0",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
