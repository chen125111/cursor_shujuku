NODE_ENV=development
PORT=4000
APP_NAME=lab-management-backend

# PostgreSQL (Prisma)
# 示例：postgresql://postgres:postgres@localhost:5432/lab?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lab?schema=public"

# JWT
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20

