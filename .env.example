# ==========================================
# 实验室管理系统 - 环境变量示例
# 复制为 .env 并修改
# ==========================================

# 安全密钥（生产环境必须修改）
SECRET_KEY=your-super-secret-key-change-in-production-2024

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 数据库（留空使用 SQLite）
DATABASE_URL=
SECURITY_DATABASE_URL=

# SQLite 路径（Docker 内）
DATABASE_PATH=/app/data/gas_data.db
SECURITY_DB_PATH=/app/data/security.db

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_ENABLED=true

# MySQL（使用 --profile mysql 时）
# MYSQL_ROOT_PASSWORD=rootpassword
# MYSQL_USER=gasapp
# MYSQL_PASSWORD=gasapp_password

# 备份
BACKUP_DIR=/app/backups
BACKUP_ENABLED=true

# CORS（逗号分隔）
CORS_ORIGINS=

# 时区
TZ=Asia/Shanghai

# 监控（可选）
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin

# Let's Encrypt
# CERTBOT_EMAIL=admin@yourdomain.com
# CERTBOT_DOMAINS=lab.yourdomain.com

# 部署（GitHub Actions）
# DEPLOY_HOST=
# DEPLOY_USER=
# DEPLOY_PATH=
