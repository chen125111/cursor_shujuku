# ================================
# 气体水合物相平衡查询系统 配置模板
# ================================
#
# 使用方法：
# 1) 复制为 .env
#    cp .env.example .env
# 2) 按需修改后启动：
#    - 本地：set -a && . ./.env && set +a && uvicorn backend.main:app --reload
#    - Docker：docker compose up -d
#
# 注意：
# - 不要把真实的 .env 提交到仓库（已在 .gitignore 中忽略）
# - 生产环境务必设置强 SECRET_KEY，并配置 ADMIN_PASSWORD
#

# ----------------
# 基础安全配置
# ----------------
# JWT 签名密钥（生产环境必须修改，建议使用随机长字符串）
SECRET_KEY=change-me-in-production

# 默认管理员账号/密码（未设置 ADMIN_PASSWORD 时，管理员登录将被禁用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=AdminPass123!

# 允许跨域来源（多个用英文逗号分隔；留空表示不启用跨域）
# 示例：CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=

# ----------------
# 数据库配置
# ----------------
# 选择其一：
# - SQLite：使用 DATABASE_PATH / SECURITY_DB_PATH
# - MySQL：设置 DATABASE_URL / SECURITY_DATABASE_URL（优先级更高）

# SQLite 文件路径（容器内建议映射到 /app/data 下）
DATABASE_PATH=./data/gas_data.db
SECURITY_DB_PATH=./data/security.db

# MySQL 连接字符串（示例，按实际替换）
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/gas_data
# SECURITY_DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/gas_security
DATABASE_URL=
SECURITY_DATABASE_URL=

# ----------------
# 备份配置（仅 SQLite 文件备份）
# ----------------
# 备份开关：1/true/on 启用；0/false/off 禁用
BACKUP_ENABLED=1
BACKUP_DIR=./backups

# ----------------
# 缓存配置（可选：Redis）
# ----------------
# 缓存开关：1/true/on 启用；0/false/off 禁用
CACHE_ENABLED=0

# 推荐使用 REDIS_URL（优先）；也可使用 REDIS_HOST/PORT/DB/PASSWORD 组合
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 业务侧 Redis key 前缀（避免与其它服务冲突）
REDIS_PREFIX=gasapp

# 缓存默认 TTL（秒）
CACHE_DEFAULT_TTL=300

# ----------------
# MySQL 连接池/超时（仅在 MySQL 模式下生效）
# ----------------
DB_POOL_ENABLED=1
DB_POOL_MAX=10
DB_POOL_MIN=1
DB_POOL_MAX_CACHED=5
DB_CONNECT_TIMEOUT=5
DB_READ_TIMEOUT=10
DB_WRITE_TIMEOUT=10
DB_CONNECT_RETRIES=2
DB_CONNECT_RETRY_DELAY=0.5

