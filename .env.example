## 示例环境变量（复制为 .env 后按需修改）
## 安全：务必替换 SECRET_KEY / ADMIN_PASSWORD

# ===== 基础 =====
TZ=Asia/Shanghai

# ===== 认证与会话 =====
# 强烈建议使用长随机字符串
SECRET_KEY=change-me-to-a-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# 可选：JWT 发行方/受众（用于多环境隔离）
# JWT_ISSUER=gas-app
# JWT_AUDIENCE=gas-app-users

# ===== 数据库（默认使用 SQLite PATH；如需 MySQL 则设置 DATABASE_URL/SECURITY_DATABASE_URL）=====
DATABASE_PATH=/app/data/gas_data.db
SECURITY_DB_PATH=/app/data/security.db

# MySQL 示例（如启用，会覆盖 PATH）
# DATABASE_URL=mysql://user:pass@host:3306/gas_data
# SECURITY_DATABASE_URL=mysql://user:pass@host:3306/security_data

# ===== Redis 缓存 / 限流存储 =====
CACHE_ENABLED=1
REDIS_URL=redis://redis:6379/0
REDIS_PREFIX=gasapp

# 默认禁用 pickle 反序列化（更安全）
# 如确有需要再开启
CACHE_ALLOW_PICKLE=0

# ===== 公开接口 API Key（可选）=====
# PUBLIC_API_KEY_REQUIRED=1
# PUBLIC_API_KEYS=key1,key2,key3

# ===== 反向代理（如 Nginx/Ingress）=====
# TRUST_PROXY_HEADERS=1

# ===== 限流配置（可按需调大/调小）=====
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_BLOCK_DURATION=300

LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_DURATION=900

# ===== SQLite 连接优化 =====
SQLITE_TIMEOUT=5

